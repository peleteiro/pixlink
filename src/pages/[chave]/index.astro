---
import ErrorPage from "@/components/ErrorPage.astro";
import PixCalculator from "@/components/PixCalculator";
import PixPage from "@/components/PixPage.astro";
import Base from "@/layouts/Base.astro";
import {
  montarDadosPix,
  parsearChave,
  parsearPayloadPix,
  type DadosPix,
} from "@/lib/pix";

const { chave: chaveRaw } = Astro.params;

// "PIX copia e cola": se o segmento e o payload EMV inteiro, renderiza o
// QR Code do PROPRIO payload — preservando txid/merchant name/city que
// marketplaces (Mercado Pago etc.) usam pra reconciliar. NUNCA redireciona
// pra calculadora, mesmo sem valor: a calculadora regeraria o payload e
// perderia o txid. Sem valor, a pagina mostra o QR como "valor a definir"
// pro app do banco capturar o valor na hora de pagar.
let dadosPayload: DadosPix | undefined;
let descricaoPayload: string | undefined;
if (chaveRaw) {
  const payload = parsearPayloadPix(chaveRaw);
  if (payload) {
    const parsedChave = parsearChave(payload.chave);
    if (parsedChave) {
      dadosPayload = montarDadosPix(
        parsedChave,
        payload.valorCentavos,
        Astro.url.origin,
        payload.descricao,
        chaveRaw,
      );
      descricaoPayload = payload.descricao;
    }
  }
}

const parsed = !dadosPayload && chaveRaw ? parsearChave(chaveRaw) : undefined;

if (!dadosPayload && !parsed) {
  Astro.response.status = 400;
}
---

{
  dadosPayload ? (
    <PixPage dados={dadosPayload} descricao={descricaoPayload} />
  ) : !parsed ? (
    <Base
      titulo="Chave invalida — pixlink"
      descricao="A chave PIX informada na URL nao e valida."
    >
      <ErrorPage
        titulo="Chave invalida"
        mensagem="A chave PIX informada na URL nao e valida. Verifique o formato e tente novamente."
      />
    </Base>
  ) : (
    <Base
      titulo={`PIX para ${parsed.display}`}
      descricao={`Calcule o valor e pague via PIX para ${parsed.label}: ${parsed.display}.`}
    >
      <PixCalculator
        chave={parsed.chave}
        label={parsed.label}
        display={parsed.display}
        client:only="react"
      />
    </Base>
  )
}
