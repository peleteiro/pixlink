---
import CopyButton from "@/components/CopyButton";
import ErrorPage from "@/components/ErrorPage.astro";
import ShareButton from "@/components/ShareButton";
import Base from "@/layouts/Base.astro";
import { montarDadosPix, parseValorUrl, parsearChave } from "@/lib/pix";

const { chave: chaveRaw, valor: valorStr } = Astro.params;
const valorCentavos = valorStr ? parseValorUrl(valorStr) : undefined;
const parsed = chaveRaw ? parsearChave(chaveRaw) : undefined;
const descricao = Astro.url.searchParams.get("d") ?? undefined;

if (!parsed || valorCentavos === undefined) {
  Astro.response.status = 400;
}

const dados =
  parsed && valorCentavos !== undefined
    ? montarDadosPix(parsed, valorCentavos, Astro.url.origin, descricao)
    : undefined;
---

{
  !dados ? (
    <Base
      titulo="Link invalido — pixlink"
      descricao="A URL nao bate com o formato esperado."
    >
      <ErrorPage
        titulo="Link invalido"
        mensagem="A chave PIX ou o valor informado na URL nao sao validos. Verifique o formato e tente novamente."
      />
    </Base>
  ) : (
    <Base
      titulo={dados.titulo}
      descricao={dados.resumo}
      canonical={dados.canonicalUrl}
      ogImage={dados.imagemUrl}
      ogImageAlt={`QR Code PIX de ${dados.valorFormatado}`}
    >
      <div class="w-full max-w-md overflow-hidden rounded-2xl bg-white shadow-lg">
        {/* Header */}
        <div class="bg-gradient-to-br from-emerald-500 to-teal-400 px-8 py-7 text-center">
          <h1 class="mb-2 text-sm font-semibold uppercase tracking-widest text-white/85">
            Pagamento via PIX
          </h1>
          <div class="text-[40px] font-bold tracking-tight text-white">
            {dados.valorFormatado}
          </div>
        </div>

        {/* Body */}
        <div class="p-8">
          {/* QR Code */}
          <div
            role="img"
            aria-label={`QR Code PIX de ${dados.valorFormatado}`}
            class="mb-6 flex items-center justify-center rounded-2xl border-2 border-gray-200 bg-white p-4 [&>svg]:block [&>svg]:h-auto [&>svg]:w-full"
          >
            <Fragment set:html={dados.svg} />
          </div>

          {/* Info */}
          <div class="mb-6 flex flex-col gap-3">
            <div class="flex items-center justify-between px-1">
              <span class="text-[13px] font-medium text-gray-400">
                {dados.label}
              </span>
              <span class="text-sm font-semibold text-gray-900">
                {dados.display}
              </span>
            </div>
            {descricao && (
              <>
                <div class="h-px bg-gray-100" />
                <div class="flex items-center justify-between px-1">
                  <span class="text-[13px] font-medium text-gray-400">
                    Descricao
                  </span>
                  <span class="text-sm font-semibold text-gray-900">
                    {descricao}
                  </span>
                </div>
              </>
            )}
            <div class="h-px bg-gray-100" />
            <div class="flex items-center justify-between px-1">
              <span class="text-[13px] font-medium text-gray-400">Valor</span>
              <span class="text-sm font-semibold text-gray-900">
                {dados.valorFormatado}
              </span>
            </div>
          </div>

          {/* Botoes */}
          <CopyButton payload={dados.payload} client:load />
          <ShareButton
            url={dados.canonicalUrl}
            valor={dados.valorFormatado}
            client:load
          />

          {/* Instrucoes */}
          <div class="mt-5 rounded-xl bg-gray-50 p-5">
            <h2 class="mb-3 text-[13px] font-semibold uppercase tracking-wide text-gray-400">
              Como pagar
            </h2>
            <ol class="flex list-decimal flex-col gap-2 pl-5">
              <li class="text-sm leading-relaxed text-gray-500">
                Abra o app do seu banco ou carteira digital
              </li>
              <li class="text-sm leading-relaxed text-gray-500">
                Escolha pagar com <strong class="text-gray-700">PIX</strong>
              </li>
              <li class="text-sm leading-relaxed text-gray-500">
                Escaneie o QR Code acima ou cole o codigo copiado
              </li>
              <li class="text-sm leading-relaxed text-gray-500">
                Confirme o pagamento
              </li>
            </ol>
          </div>
        </div>

        {/* Footer */}
        <div class="pb-6 text-center text-xs text-gray-300">
          pix.peleteiro.net
        </div>
      </div>
    </Base>
  )
}
