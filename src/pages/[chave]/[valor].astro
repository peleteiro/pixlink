---
import CopyButton from "../../components/CopyButton";
import ShareButton from "../../components/ShareButton";
import { formatValor, gerarPayloadPix, parsearChave } from "../../lib/pix";
import { gerarSvg } from "../../lib/qrcode";
import "../../styles/global.css";

const { chave: chaveRaw, valor: valorStr } = Astro.params;

const valorCentavos = parseInt(valorStr!, 10);
const parsed = chaveRaw ? parsearChave(decodeURIComponent(chaveRaw)) : undefined;

if (!parsed || !valorStr || isNaN(valorCentavos) || valorCentavos <= 0) {
  return new Response("Chave ou valor invalido. Use /{chave-pix}/{centavos}", {
    status: 400,
  });
}

const descricao = Astro.url.searchParams.get("d") ?? undefined;
const payload = gerarPayloadPix(parsed.chave, valorCentavos, descricao);
const svg = gerarSvg(payload);
const valorFormatado = formatValor(valorCentavos);

// Meta tags para previews (WhatsApp/Telegram/etc usam Open Graph).
// A imagem aponta para a propria rota .png, que serve o QR Code em 1024x1024.
const titulo = `PIX ${valorFormatado}`;
const resumo = descricao
  ? `${parsed.label}: ${parsed.display} — ${descricao}`
  : `${parsed.label}: ${parsed.display}`;
const urlAtual = Astro.url.href;
const imagemUrl = `${Astro.url.origin}${Astro.url.pathname}.png${Astro.url.search}`;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo}</title>
    <meta name="description" content={resumo} />

    <!-- Open Graph (WhatsApp, Telegram, Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="pixlink" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={resumo} />
    <meta property="og:url" content={urlAtual} />
    <meta property="og:image" content={imagemUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content={`QR Code PIX de ${valorFormatado}`} />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={resumo} />
    <meta name="twitter:image" content={imagemUrl} />
  </head>

  <body
    class="flex min-h-dvh items-center justify-center bg-gray-100 p-6 font-sans text-gray-900 antialiased"
  >
    <div class="w-full max-w-md overflow-hidden rounded-2xl bg-white shadow-lg">
      <!-- Header -->
      <div
        class="bg-gradient-to-br from-emerald-500 to-teal-400 px-8 py-7 text-center"
      >
        <h1
          class="mb-2 text-sm font-semibold uppercase tracking-widest text-white/85"
        >
          Pagamento via PIX
        </h1>
        <div class="text-[40px] font-bold tracking-tight text-white">
          {valorFormatado}
        </div>
      </div>

      <!-- Body -->
      <div class="p-8">
        <!-- QR Code -->
        <div
          class="mb-6 flex items-center justify-center rounded-2xl border-2 border-gray-200 bg-white p-4 [&>svg]:block [&>svg]:h-auto [&>svg]:w-full"
        >
          <Fragment set:html={svg} />
        </div>

        <!-- Info -->
        <div class="mb-6 flex flex-col gap-3">
          <div class="flex items-center justify-between px-1">
            <span class="text-[13px] font-medium text-gray-400">
              {parsed.label}
            </span>
            <span class="text-sm font-semibold text-gray-900">
              {parsed.display}
            </span>
          </div>
          {descricao && (
            <>
              <div class="h-px bg-gray-100"></div>
              <div class="flex items-center justify-between px-1">
                <span class="text-[13px] font-medium text-gray-400">
                  Descricao
                </span>
                <span class="text-sm font-semibold text-gray-900">
                  {descricao}
                </span>
              </div>
            </>
          )}
          <div class="h-px bg-gray-100"></div>
          <div class="flex items-center justify-between px-1">
            <span class="text-[13px] font-medium text-gray-400">Valor</span>
            <span class="text-sm font-semibold text-gray-900">
              {valorFormatado}
            </span>
          </div>
        </div>

        <!-- Botoes -->
        <CopyButton payload={payload} client:load />
        <ShareButton url={Astro.url.href} valor={valorFormatado} client:load />

        <!-- Instrucoes -->
        <div class="mt-5 rounded-xl bg-gray-50 p-5">
          <h2
            class="mb-3 text-[13px] font-semibold uppercase tracking-wide text-gray-400"
          >
            Como pagar
          </h2>
          <ol class="flex list-decimal flex-col gap-2 pl-5">
            <li class="text-sm leading-relaxed text-gray-500">
              Abra o app do seu banco ou carteira digital
            </li>
            <li class="text-sm leading-relaxed text-gray-500">
              Escolha pagar com <strong class="text-gray-700">PIX</strong>
            </li>
            <li class="text-sm leading-relaxed text-gray-500">
              Escaneie o QR Code acima ou cole o codigo copiado
            </li>
            <li class="text-sm leading-relaxed text-gray-500">
              Confirme o pagamento
            </li>
          </ol>
        </div>
      </div>

      <!-- Footer -->
      <div class="pb-6 text-center text-xs text-gray-300">
        pix.peleteiro.net
      </div>
    </div>
  </body>
</html>
