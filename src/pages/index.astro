---
import PixForm from "@/components/PixForm";
import Base from "@/layouts/Base.astro";

const canonical = `${Astro.url.origin}/`;
---

<Base
  titulo="PIX QR Code Generator — pix.peleteiro.net"
  descricao="Gere um link que exibe um QR Code PIX de pagamento. Cole o link onde quiser — nada e salvo em servidor, os dados ficam na propria URL."
  canonical={canonical}
>
  <div class="w-full max-w-lg">
    <div class="overflow-hidden rounded-2xl bg-white shadow-lg">
      <!-- Header -->
      <div
        class="bg-gradient-to-br from-emerald-500 to-teal-400 px-8 py-7 text-center"
      >
        <h1 class="text-2xl font-bold tracking-tight text-white">PIX QR Code</h1>
        <p class="mt-2 text-sm text-white/80">
          Gere um link que exibe um QR Code de pagamento PIX
        </p>
      </div>

      <!-- Form -->
      <div class="p-8">
        <PixForm client:load />
      </div>

      <!-- Aviso de privacidade -->
      <div class="border-t border-gray-100 bg-gray-50 px-8 py-4">
        <p class="text-center text-xs leading-relaxed text-gray-500">
          Nada e salvo em servidor. O link gerado contem a chave e o valor na
          propria URL — quando aberto, o QR Code e remontado a partir desses
          dados.
        </p>
      </div>
    </div>

    <!-- Documentacao -->
    <div class="mt-6 rounded-2xl bg-white p-8 shadow-lg">
      <h2 class="mb-4 text-lg font-bold text-gray-900">Formato da URL</h2>

      <div class="rounded-lg bg-gray-50 px-4 py-3">
        <code class="text-sm text-emerald-700">
          /{"{chave-pix}"}/{"{valor}"}?d={"{descricao}"}
        </code>
      </div>

      <!-- Parametros -->
      <div class="mt-6 flex flex-col gap-4">
        <div>
          <h3 class="text-sm font-semibold text-gray-900">chave-pix</h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500">
            A chave PIX do recebedor. Aceita:
          </p>
          <ul class="mt-2 flex flex-col gap-1.5 pl-4">
            <li class="text-sm text-gray-500">
              <strong class="font-medium text-gray-700">Telefone</strong> —
              <code class="text-xs text-emerald-700">21992446550</code>,
              <code class="text-xs text-emerald-700">5521992446550</code> ou
              <code class="text-xs text-emerald-700">+5521992446550</code>
            </li>
            <li class="text-sm text-gray-500">
              <strong class="font-medium text-gray-700">CPF</strong> —
              <code class="text-xs text-emerald-700">052.868.827-81</code> ou
              <code class="text-xs text-emerald-700">05286882781</code>
            </li>
            <li class="text-sm text-gray-500">
              <strong class="font-medium text-gray-700">CNPJ</strong> —
              <code class="text-xs text-emerald-700">12.345.678/0001-95</code> ou
              <code class="text-xs text-emerald-700">12345678000195</code>
            </li>
            <li class="text-sm text-gray-500">
              <strong class="font-medium text-gray-700">E-mail</strong> —
              <code class="text-xs text-emerald-700">jose@peleteiro.net</code>
            </li>
            <li class="text-sm text-gray-500">
              <strong class="font-medium text-gray-700">Chave aleatoria</strong>
              — UUID com ou sem hifens:
              <code class="text-xs text-emerald-700"
                >123e4567-e89b-12d3-a456-426614174000</code
              >
            </li>
          </ul>
        </div>

        <div class="h-px bg-gray-100"></div>

        <div>
          <h3 class="text-sm font-semibold text-gray-900">valor</h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500">
            Em reais, com <code class="text-xs text-emerald-700">,</code>
            separando os centavos. Ex:
            <code class="text-xs text-emerald-700">50,00</code> ou
            <code class="text-xs text-emerald-700">50</code> = R$ 50,00.
          </p>
        </div>

        <div class="h-px bg-gray-100"></div>

        <div>
          <h3 class="text-sm font-semibold text-gray-900">
            ?d= <span class="font-normal text-gray-400">(opcional)</span>
          </h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500">
            Descricao do pagamento, incluida no payload PIX.
          </p>
        </div>

        <div class="h-px bg-gray-100"></div>

        <div>
          <h3 class="text-sm font-semibold text-gray-900">
            .png <span class="font-normal text-gray-400">(formato)</span>
          </h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500">
            Adicione <code class="text-xs text-emerald-700">.png</code> ao final
            do valor para receber apenas a imagem do QR Code em PNG (1024x1024).
            Util para embedar em e-mails, mensagens ou documentos.
          </p>
        </div>
      </div>

      <!-- Exemplos -->
      <h3 class="mt-6 mb-3 text-sm font-semibold text-gray-900">Exemplos</h3>
      <div class="flex flex-col gap-2">
        <a
          href="/21992446550/50,00"
          class="block rounded-lg bg-gray-50 px-4 py-2.5 text-sm text-emerald-700 transition-colors hover:bg-emerald-50"
        >
          /21992446550/50,00
        </a>
        <a
          href="/052.868.827-81/15"
          class="block rounded-lg bg-gray-50 px-4 py-2.5 text-sm text-emerald-700 transition-colors hover:bg-emerald-50"
        >
          /052.868.827-81/15
        </a>
        <a
          href="/12.345.678%2F0001-95/250,00"
          class="block rounded-lg bg-gray-50 px-4 py-2.5 text-sm text-emerald-700 transition-colors hover:bg-emerald-50"
        >
          /12.345.678/0001-95/250,00
        </a>
        <a
          href="/123e4567-e89b-12d3-a456-426614174000/50"
          class="block rounded-lg bg-gray-50 px-4 py-2.5 text-sm text-emerald-700 transition-colors hover:bg-emerald-50"
        >
          /123e4567-e89b-12d3-a456-426614174000/50
        </a>
        <a
          href="/jose@peleteiro.net/100?d=Consultoria"
          class="block rounded-lg bg-gray-50 px-4 py-2.5 text-sm text-emerald-700 transition-colors hover:bg-emerald-50"
        >
          /jose@peleteiro.net/100?d=Consultoria
        </a>
        <a
          href="/21992446550/50,00.png"
          class="block rounded-lg bg-gray-50 px-4 py-2.5 text-sm text-emerald-700 transition-colors hover:bg-emerald-50"
        >
          /21992446550/50,00.png
        </a>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-6 text-center text-xs text-gray-300">pix.peleteiro.net</div>
  </div>
</Base>
