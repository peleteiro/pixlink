---
interface Props {
  titulo: string;
  mensagem: string;
}

const { titulo, mensagem } = Astro.props;
---

<div class="w-full max-w-md overflow-hidden rounded-2xl bg-white shadow-lg">
  <div
    class="bg-gradient-to-br from-rose-500 to-orange-400 px-8 py-7 text-center"
  >
    <h1 class="text-2xl font-bold tracking-tight text-white">{titulo}</h1>
  </div>

  <div class="p-8">
    <p class="mb-6 text-sm leading-relaxed text-gray-600">{mensagem}</p>

    <div class="rounded-xl bg-gray-50 p-5">
      <h2
        class="mb-3 text-[13px] font-semibold uppercase tracking-wide text-gray-400"
      >
        Formato esperado
      </h2>
      <code class="block text-sm text-emerald-700">
        /{`{chave-pix}`}/{`{valor}`}
      </code>
      <p class="mt-3 text-xs leading-relaxed text-gray-500">
        Ex: <code class="text-emerald-700">/21992446550/50,00</code>
      </p>
    </div>

    <a href="/" class="btn-primary mt-5 block text-center">
      Voltar para a home
    </a>
  </div>

  <div class="pb-6 text-center text-xs text-gray-300">pix.peleteiro.net</div>
</div>
